{
  "name": "dcs-platform-app-demo",
  "private": true,
  "version": "0.1.0",
  "description": "数据跨境服务平台产品展示版",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "typecheck:web": "tsc --noEmit -p tsconfig.json",
    "typecheck:electron": "tsc --noEmit -p electron/tsconfig.json",
    "typecheck": "npm-run-all typecheck:web typecheck:electron",
    "build:web": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm-run-all typecheck build:web build:electron",
    "dev:electron:tsc": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron:start": "wait-on http://127.0.0.1:5173 file:dist-electron/main.js && electron dist-electron/main.js",
    "electron:dev": "concurrently -k -s first \"npm:dev:electron:tsc\" \"npm:dev\" \"npm:dev:electron:start\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.1",
    "antd": "^5.28.0",
    "dayjs": "^1.11.13",
    "echarts": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.7.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.12",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.demo.dcs-platform",
    "productName": "数据跨境服务平台",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  }
}
